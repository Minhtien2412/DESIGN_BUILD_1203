# ============================
# AI Brain (VPS2) Configuration
# ============================

# Server
PORT=8088
NODE_ENV=production

# OpenClaw Gateway (loopback only)
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=CHANGE_THIS_OPENCLAW_TOKEN

# Service-to-service auth (must match VPS1 AI_INTERNAL_TOKEN)
AI_INTERNAL_TOKEN=CHANGE_THIS_AI_INTERNAL_TOKEN

# Policy
AI_POLICY_VERSION=ts-v2

# Redis (via Tailscale to VPS1 for initial phase)
# REDIS_URL=redis://app-core:6379/2

# OpenAI (for policy classifier — Wave 3)
# OPENAI_API_KEY=sk-proj-CHANGE_THIS
