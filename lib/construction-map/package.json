{
  "name": "@construction-app/canvas-map",
  "version": "0.1.0",
  "description": "2D infinite canvas library for construction progress visualization",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "canvas",
    "infinite-canvas",
    "construction",
    "visualization",
    "2d",
    "zoom",
    "pan"
  ],
  "author": "Construction App Team",
  "license": "MIT",
  "dependencies": {
    "gl-matrix": "^3.4.3",
    "hammerjs": "^2.0.8",
    "rbush": "^3.0.1",
    "bezier-easing": "^2.1.0"
  },
  "devDependencies": {
    "@types/hammerjs": "^2.0.45",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
