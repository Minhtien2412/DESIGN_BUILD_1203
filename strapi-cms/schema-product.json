{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "San pham trong he thong"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "price": {
      "type": "decimal",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": ["ELECTRONICS", "FASHION", "HOME", "BEAUTY", "FOOD", "OTHER"],
      "default": "OTHER"
    },
    "stock": {
      "type": "integer",
      "default": 0
    },
    "status": {
      "type": "enumeration",
      "enum": ["PENDING", "APPROVED", "REJECTED"],
      "default": "PENDING"
    },
    "isBestseller": {
      "type": "boolean",
      "default": false
    },
    "isNew": {
      "type": "boolean",
      "default": true
    }
  }
}
