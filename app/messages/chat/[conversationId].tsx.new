/**
 * Conversation Chat Screen Redirect
 * Redirects to unified chat screen at /messages/[userId]
 * This file exists for backward compatibility
 * @updated 2026-01-26
 */

import { Redirect, useLocalSearchParams } from "expo-router";

export default function ConversationChatRedirect() {
  const { conversationId } = useLocalSearchParams<{ conversationId: string }>();

  // Redirect to main messages user chat
  return <Redirect href={`/messages/${conversationId || "0"}`} />;
}
