{
  "cli": { "version": ">= 4.0.0", "appVersionSource": "remote" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk" }
    },
    "preview": {
      "distribution": "internal",
      "android": { 
        "buildType": "apk",
        "withoutCredentials": false
      }
    },
    "production": {
      "android": { "buildType": "app-bundle" }
    }
  }
}
