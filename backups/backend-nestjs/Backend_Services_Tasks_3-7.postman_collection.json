            "body": {
              "mode": "raw",
              "raw": "{\n  \"entityType\": \"project\",\n  \"entityId\": {{projectId}},\n  \"content\": \"Great progress on this project! @john keep up the good work 👍\",\n  \"userId\": {{userId}},\n  \"userName\": \"Jane Doe\",\n  \"userAvatar\": \"https://example.com/avatar.jpg\",\n  \"mentions\": [\"john\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/comments",
              "host": ["{{baseUrl}}"],
              "path": ["comments"]
