    {
      "name": "Scheduled Tasks API",
      "item": [
        {
          "name": "Create Daily Reminder",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Daily Project Update Reminder\",\n  \"description\": \"Send reminder to update project progress\",\n  \"scheduleType\": \"daily\",\n  \"action\": \"send_reminder\",\n  \"parameters\": {\n    \"message\": \"Please update your project progress\",\n    \"recipients\": [\"admin@example.com\"]\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/scheduled-tasks",
              "host": ["{{baseUrl}}"],
              "path": ["scheduled-tasks"]
            }
          }
        },
        {
          "name": "Create Weekly Report",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Weekly Progress Report\",\n  \"description\": \"Generate and send weekly progress report\",\n  \"scheduleType\": \"weekly\",\n  \"action\": \"generate_report\",\n  \"parameters\": {\n    \"reportType\": \"weekly_progress\",\n    \"format\": \"pdf\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/scheduled-tasks",
              "host": ["{{baseUrl}}"],
              "path": ["scheduled-tasks"]
            }
          }
        },
        {
          "name": "List All Tasks",
          "request": {
            "method": "GET",
            "header": [],
