# Server Configuration
NODE_ENV=production
PORT=3001
API_PREFIX=api

# Database - PostgreSQL
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=construction_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_DATABASE=construction_map
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Alternative: MongoDB
# DB_TYPE=mongodb
# MONGO_URI=mongodb://localhost:27017/construction_map

# JWT Authentication
JWT_SECRET=CHANGE_ME_RANDOM_SECRET_KEY_MIN_32_CHARS
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# CORS Origins (comma separated)
CORS_ORIGIN=https://yourdomain.com,exp://192.168.1.100:8081

# WebSocket
WS_PORT=3002
WS_PATH=/ws/construction-map

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600

# File Upload
UPLOAD_DESTINATION=./uploads
MAX_FILE_SIZE=10485760

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# WebSocket Events Throttle (ms)
WS_THROTTLE_MS=100
