    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "@types/react-native": "^0.72.8",
    "concurrently": "^9.2.1",
    "eslint": "^9.35.0",
    "eslint-config-expo": "~10.0.0",
