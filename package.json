{
  "name": "app_design_build",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:dev": "node scripts/start-dev.js",
    "mock-server": "node mock-api-server.js",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "typecheck:app": "tsc --project tsconfig.app.json --noEmit",
    "videos:generate": "node ./scripts/generate-video-manifest.cjs",
    "videos:generate:big": "cross-env VIDEOS_MAX_MB=200 node ./scripts/generate-video-manifest.cjs",
    "media:check": "powershell -ExecutionPolicy Bypass -File ./scripts/check-media-sizes.ps1",
    "compress:video": "powershell -ExecutionPolicy Bypass -File ./scripts/ffmpeg-compress.ps1",
    "openapi:types": "node ./scripts/generate-openapi-types.cjs",
    "build:preview": "eas build --profile preview --platform android",
    "build:preview:optimized": "powershell -ExecutionPolicy Bypass -File ./build-apk-optimized.ps1",
    "build:production": "eas build --profile production --platform android",
    "build:dev:android": "eas build -p android --profile development",
    "build:dev:ios": "eas build -p ios --profile development",
    "build:list": "eas build:list",
    "run:dev:android": "npx expo run:android",
    "run:dev:ios": "npx expo run:ios",
    "setup:dev-build": "node ./scripts/setup-dev-build.js",
    "clean:cache": "npx expo start -c",
    "clean:native": "rm -rf android ios",
    "rebuild:android": "npm run clean:native && npx expo prebuild && npm run run:dev:android"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
