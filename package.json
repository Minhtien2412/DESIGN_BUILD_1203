  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.0.3",
    "@types/react": "~19.1.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.35.0",
    "eslint-config-expo": "~10.0.0",
    "graceful-fs": "^4.2.11",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.16",
    "openapi-typescript": "^7.9.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  },
  "browser": {
    "fontfaceobserver": "./mock-fontfaceobserver.js",
    "react-native-maps": "./mock-react-native-maps.js"
  },
  "overrides": {
    "event-target-shim": "6.0.2",
    "react-native-safe-area-context": "5.6.1"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": []
      }
    }
  },
  "private": true
