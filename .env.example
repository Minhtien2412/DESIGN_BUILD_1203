# =============================================================================
# Environment Configuration
# =============================================================================
EXPO_PUBLIC_ENV=production

# =============================================================================
# Backend API (Fastify @ 127.0.0.1:4000, public via Nginx)
# =============================================================================
# Production: https://api.thietkeresort.com.vn
# Healthcheck: GET /health → {"status":"ok","ts":...}
# Auth: JWT Bearer token (86400s expiry)
#
# Local Development Override (uncomment for local backend):
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:4000  # Android emulator
# EXPO_PUBLIC_API_BASE_URL=http://localhost:4000  # iOS simulator/web
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.x:4000  # Physical device

# API Key (if backend requires x-api-key header - optional)
# EXPO_PUBLIC_API_KEY=your_api_key_here

# =============================================================================
# LiveKit Server (WebRTC @ 127.0.0.1:7880, public via Nginx /livekit/)
# =============================================================================
# Production: wss://api.thietkeresort.com.vn/livekit/rtc
# ⚠️ Must include /rtc suffix for WebSocket handshake
#
# Local Development:
# EXPO_PUBLIC_LIVEKIT_WS_URL=ws://10.0.2.2:7880  # Android emulator
# EXPO_PUBLIC_LIVEKIT_WS_URL=ws://localhost:7880  # iOS simulator
EXPO_PUBLIC_LIVEKIT_WS_URL=wss://api.thietkeresort.com.vn/livekit/rtc

# Debug mode (show verbose API logs in console)
EXPO_PUBLIC_API_DEBUG=0

# Remote auth toggle
EXPO_PUBLIC_REMOTE_AUTH=0

# Optional: separate Node API base (if different from main API)
# EXPO_PUBLIC_NODE_API_BASE_URL=https://your-node-api.example

# Optional: videos JSON endpoint
# EXPO_PUBLIC_VIDEOS_URL=https://cdn.example.com/videos.json

# =============================================================================
# WebSocket / Socket.IO
# =============================================================================
# EXPO_PUBLIC_WS_BASE_URL=wss://baotienweb.cloud
# EXPO_PUBLIC_WS_URL=wss://baotienweb.cloud
# EXPO_PUBLIC_WS_PROGRESS_URL=wss://baotienweb.cloud/progress

# =============================================================================
# API Key (Fastify x-api-key header)
# =============================================================================
EXPO_PUBLIC_API_KEY=your-api-key-here

# =============================================================================
# Perfex CRM Integration
# =============================================================================
# EXPO_PUBLIC_PERFEX_CRM_URL=https://your-domain.com/perfex_crm
# EXPO_PUBLIC_PERFEX_API_TOKEN=your-perfex-jwt-token
# EXPO_PUBLIC_PERFEX_API_KEY=your-perfex-api-key

# =============================================================================
# GetOTP (SMS OTP Service - https://otp.dev)
# =============================================================================
# EXPO_PUBLIC_GETOTP_API_KEY=your-getotp-api-key

# =============================================================================
# Google OAuth
# =============================================================================
# EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id
# EXPO_PUBLIC_GOOGLE_CLIENT_SECRET=your-google-client-secret
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id

# =============================================================================
# AI Keys (Optional)
# =============================================================================
# EXPO_PUBLIC_OPENAI_API_KEY=sk-...
# EXPO_PUBLIC_GEMINI_API_KEY=...
# EXPO_PUBLIC_PEXELS_API_KEY=...
# EXPO_PUBLIC_GNEWS_API_KEY=...

# =============================================================================
# LiveKit (Video Calls/Meetings)
# =============================================================================
# EXPO_PUBLIC_LIVEKIT_URL=wss://your-livekit-server.com
# EXPO_PUBLIC_LIVEKIT_API_KEY=your-livekit-api-key
# EXPO_PUBLIC_LIVEKIT_API_SECRET=your-livekit-secret

# =============================================================================
# Cloud Storage (Optional)
# =============================================================================
# EXPO_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# EXPO_PUBLIC_AWS_REGION=ap-southeast-1
# EXPO_PUBLIC_AWS_S3_BUCKET=your-bucket
# EXPO_PUBLIC_AWS_ACCESS_KEY_ID=your-access-key
# EXPO_PUBLIC_AWS_SECRET_ACCESS_KEY=your-secret-key
# EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
# EXPO_PUBLIC_CLOUDINARY_API_KEY=your-cloudinary-key
# EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-preset
