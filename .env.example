# =============================================================================
# Environment Configuration
# Copy this file to .env and fill in your values.
# Variables prefixed with EXPO_PUBLIC_ are bundled into the app at build time.
# =============================================================================

# =============================================================================
# App Environment
# =============================================================================
EXPO_PUBLIC_ENV=production

# =============================================================================
# Backend API (Fastify @ 127.0.0.1:4000, public via Nginx)
# =============================================================================
# Production: https://baotienweb.cloud/api
# Healthcheck: GET /health → {"status":"ok","ts":...}
# Auth: JWT Bearer token (86400s expiry)
#
# Local Development Override (uncomment for local backend):
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:4000  # Android emulator
# EXPO_PUBLIC_API_BASE_URL=http://localhost:4000  # iOS simulator/web
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.x:4000  # Physical device
EXPO_PUBLIC_API_BASE_URL=https://baotienweb.cloud/api

# API Key (required - backend validates x-api-key header)
EXPO_PUBLIC_API_KEY=thietke-resort-api-key-2024

# API prefix (empty for mobile; set to /api if backend uses that prefix)
# EXPO_PUBLIC_API_PREFIX=

# Debug mode (show verbose API logs in console): 0=off, 1=on
EXPO_PUBLIC_API_DEBUG=0

# Remote auth toggle: 0=local, 1=remote
EXPO_PUBLIC_REMOTE_AUTH=0

# Optional: separate Node API base (if different from main API)
# EXPO_PUBLIC_NODE_API_BASE_URL=https://your-node-api.example

# Optional: videos JSON endpoint
# EXPO_PUBLIC_VIDEOS_URL=https://cdn.example.com/videos.json

# =============================================================================
# WebSocket / Socket.IO
# =============================================================================
# Base WebSocket URL (without namespace) - defaults to wss://baotienweb.cloud
# EXPO_PUBLIC_WS_BASE_URL=wss://baotienweb.cloud

# Legacy WS URL (optional, overrides WS_BASE_URL for all namespaces)
# EXPO_PUBLIC_WS_URL=wss://baotienweb.cloud

# Progress namespace WS URL (optional override)
# EXPO_PUBLIC_WS_PROGRESS_URL=wss://baotienweb.cloud/progress

# =============================================================================
# Auth Paths (override defaults if backend uses different paths)
# =============================================================================
# EXPO_PUBLIC_AUTH_REFRESH_PATH=/auth/refresh
# EXPO_PUBLIC_AUTH_GOOGLE_PATH=/auth/google
# EXPO_PUBLIC_AUTH_FACEBOOK_PATH=/auth/facebook

# Social login toggles: "1"=enabled, "0"=disabled
# EXPO_PUBLIC_ENABLE_SOCIAL_GOOGLE=1
# EXPO_PUBLIC_ENABLE_SOCIAL_FACEBOOK=1

# =============================================================================
# Google OAuth
# =============================================================================
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_CLIENT_SECRET=your-client-secret
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# =============================================================================
# Google Maps
# =============================================================================
# Get from: https://console.cloud.google.com → Maps JavaScript API
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# =============================================================================
# LiveKit (Video Calls / Meetings / Livestreams)
# =============================================================================
# Get credentials from: https://cloud.livekit.io
# Production WebSocket URL must include /rtc suffix for WebSocket handshake
# EXPO_PUBLIC_LIVEKIT_WS_URL=wss://api.thietkeresort.com.vn/livekit/rtc
# EXPO_PUBLIC_LIVEKIT_URL=wss://api.thietkeresort.com.vn/livekit/rtc
# EXPO_PUBLIC_LIVEKIT_API_KEY=your-livekit-api-key
# EXPO_PUBLIC_LIVEKIT_API_SECRET=your-livekit-api-secret

# =============================================================================
# Agora (Backup video platform)
# =============================================================================
# Get from: https://console.agora.io
# EXPO_PUBLIC_AGORA_APP_ID=your-agora-app-id

# =============================================================================
# AI Services
# =============================================================================
# OpenAI - https://platform.openai.com/api-keys
# EXPO_PUBLIC_OPENAI_API_KEY=sk-...

# Google Gemini - https://aistudio.google.com/app/apikey
# EXPO_PUBLIC_GEMINI_API_KEY=AIza...

# =============================================================================
# Pexels (Free Photos & Videos)
# =============================================================================
# Get from: https://www.pexels.com/api/
# EXPO_PUBLIC_PEXELS_API_KEY=your-pexels-api-key

# =============================================================================
# GNews (News Service - 100 req/day free)
# =============================================================================
# Get from: https://gnews.io/
# EXPO_PUBLIC_GNEWS_API_KEY=your-gnews-api-key

# =============================================================================
# Perfex CRM Integration
# =============================================================================
# EXPO_PUBLIC_PERFEX_CRM_URL=https://thietkeresort.com.vn/perfex_crm
# EXPO_PUBLIC_PERFEX_API_TOKEN=your-perfex-jwt-token
# EXPO_PUBLIC_PERFEX_API_KEY=your-perfex-custom-api-key

# =============================================================================
# GetOTP (SMS OTP Service - https://otp.dev)
# =============================================================================
# Supports: SMS, Viber, Voice, Telegram
# Dashboard: https://otp.dev/en/dashboard/
# EXPO_PUBLIC_GETOTP_API_KEY=your-getotp-api-key
# EXPO_PUBLIC_GETOTP_SENDER_NAME=ThietKe
# EXPO_PUBLIC_GETOTP_DEFAULT_CHANNEL=sms

# =============================================================================
# Supabase (Document Storage)
# =============================================================================
# Get from: https://supabase.com/dashboard → Project Settings → API
# EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# =============================================================================
# AWS S3 (Large Files Storage)
# =============================================================================
# EXPO_PUBLIC_AWS_REGION=ap-southeast-1
# EXPO_PUBLIC_AWS_S3_BUCKET=your-bucket-name
# EXPO_PUBLIC_AWS_ACCESS_KEY_ID=your-access-key-id
# EXPO_PUBLIC_AWS_SECRET_ACCESS_KEY=your-secret-access-key
# EXPO_PUBLIC_AWS_CLOUDFRONT_URL=https://your-cloudfront-domain.cloudfront.net

# =============================================================================
# Cloudinary (Image / Video Optimization)
# =============================================================================
# Get from: https://cloudinary.com/console
# EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
# EXPO_PUBLIC_CLOUDINARY_API_KEY=your-api-key
# EXPO_PUBLIC_CLOUDINARY_API_SECRET=your-api-secret
# EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=app_uploads

# =============================================================================
# Retry / Backoff tuning (optional)
# =============================================================================
# EXPO_PUBLIC_BACKOFF_BASE_MS=500
# EXPO_PUBLIC_BACKOFF_JITTER_MS=500

