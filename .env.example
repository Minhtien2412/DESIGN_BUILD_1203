# =============================================================================
# Environment Configuration
# =============================================================================
EXPO_PUBLIC_ENV=production

# =============================================================================
# Backend API (Fastify @ 127.0.0.1:4000, public via Nginx)
# =============================================================================
# Production: https://api.thietkeresort.com.vn
# Healthcheck: GET /health → {"status":"ok","ts":...}
# Auth: JWT Bearer token (86400s expiry)
#
# Local Development Override (uncomment for local backend):
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:4000  # Android emulator
# EXPO_PUBLIC_API_BASE_URL=http://localhost:4000  # iOS simulator/web
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.x:4000  # Physical device

# API Key (if backend requires x-api-key header - optional)
# EXPO_PUBLIC_API_KEY=your_api_key_here

# =============================================================================
# LiveKit Server (WebRTC @ 127.0.0.1:7880, public via Nginx /livekit/)
# =============================================================================
# Production: wss://api.thietkeresort.com.vn/livekit/rtc
# ⚠️ Must include /rtc suffix for WebSocket handshake
#
# Local Development:
# EXPO_PUBLIC_LIVEKIT_WS_URL=ws://10.0.2.2:7880  # Android emulator
# EXPO_PUBLIC_LIVEKIT_WS_URL=ws://localhost:7880  # iOS simulator
EXPO_PUBLIC_LIVEKIT_WS_URL=wss://api.thietkeresort.com.vn/livekit/rtc

# Debug mode (show verbose API logs in console)
EXPO_PUBLIC_API_DEBUG=0

# Remote auth toggle
EXPO_PUBLIC_REMOTE_AUTH=0

# Optional: separate Node API base (if different from main API)
# EXPO_PUBLIC_NODE_API_BASE_URL=https://your-node-api.example

# Optional: videos JSON endpoint
# EXPO_PUBLIC_VIDEOS_URL=https://cdn.example.com/videos.json
