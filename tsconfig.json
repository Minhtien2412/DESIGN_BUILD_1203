{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "types/**/*.d.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    // exclude noisy backups and legacy files created during refactors
    "**/*_BACKUP.tsx",
    "**/*.backup.ts",
    "**/*.backup.tsx",
    "**/*-old.ts",
    "**/*-old.tsx",
    "**/*.old.tsx",
    "**/*.old.ts",
    "**/api-backup.ts",
    "**/tk-api-old.ts",
    "components/**/ModernConstructionAuthScreen_CORRUPTED_BACKUP.tsx",
    "dev-backups",
    "expo-skeleton",
    "my-new-expo-app",
    // exclude perfex-crm-ai-architect separate project
    "perfex-crm-ai-architect/**",
  // exclude server/backend code from app typecheck
  "server/**",
  "backend-implementation/**",
  "backend-nestjs/**",
  "backend-archive/**",
  "backend-files/**",
  "backend/admin-web/**",
  "BE-baotienweb.cloud/**",
  "docs/backend-code/**",
  "*.controller.*.ts",
  "_archived/**",
  "__tests__/**",
  "tests/**",
  "e2e/**",
  "scripts/**",
  "backups/**",
  "lib/construction-map/examples/**",
  "lib/construction-map/vite.config.ts",
  "services/api/__tests__.ts",
    // common excludes
    "node_modules",
    "dist",
    "build",
    "ios",
    "android"
  ]
}
