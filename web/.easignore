# AGGRESSIVE BUILD SIZE REDUCTION
# Chỉ build source code app, loại bỏ tất cả phần không cần thiết

# ============================================
# GIT & VERSION CONTROL (KHÔNG CẦN)
# ============================================
.git/
.github/
.gitignore
.gitattributes

# ============================================
# DOCUMENTATION (KHÔNG CẦN)
# ============================================
docs/
*.md
!README.md
LICENSE
CHANGELOG.md

# ============================================
# BACKEND & SERVER (KHÔNG CẦN)
# ============================================
server/
backend-implementation/
perfex_crm/
prisma/
domains/
openapi/
BE-baotienweb.cloud/
strapi-cms/
admin-web/
perfex-module/

# ============================================
# ARCHIVED & BACKUP (KHÔNG CẦN)
# ============================================
_archived/
_archive/
**/_archive/
dev-backups/
expo-skeleton/
my-new-expo-app/
**/*_BACKUP.*
**/*.backup.*
**/*-old.*

# ============================================
# TESTS & SCRIPTS (KHÔNG CẦN)
# ============================================
__tests__/
tests/
scripts/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx

# ============================================
# GENERATED/BUILD FOLDERS
# ============================================
node_modules/
.expo/
.expo-shared/
dist/
web-build/
# Use CNG (Continuous Native Generation) - EAS will generate native folders
/android/
/ios/

# ============================================
# ASSETS (Only exclude large media folders)
# ============================================
# Note: Keep main assets folder for icons and splash
# assets/
dist-test/

# Keep only required icons
!assets/images/icon.png
!assets/images/splash-icon.png
!assets/images/adaptive-icon.png
!assets/images/favicon.png
!assets/images/android-icon-foreground.png
!assets/images/android-icon-background.png
!assets/images/android-icon-monochrome.png

# Exclude large media in subfolders (commented - needed by app)
# assets/images/banner/
# assets/images/home/
# assets/images/service/
# assets/images/thu-vien/
# assets/images/tien-ich-*/
!assets/splash.png
!assets/adaptive-icon.png
!assets/favicon.png

